# J.A.R.V.I.S Backend Configurations
PORT=5000

# Connection URI for local MongoDB server
MONGO_URI=mongodb://127.0.0.1:27017/jarvis

# Primary Grounded AI Brain: Google Gemini API (Get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Backup AI Brain: Groq Cloud API (Get from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
